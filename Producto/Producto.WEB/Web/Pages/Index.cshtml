@page
@model Web.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="page-hero">
    <div class="container py-2">
        <h1><i class="bi bi-box-seam me-2"></i>Gestión de Productos</h1>
        <p>Administra el catálogo de productos de forma sencilla y eficiente.</p>
    </div>
</div>

<div class="section-body">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="product-card text-center p-4">
                    <div class="mb-3" style="font-size:2.5rem;color:var(--primary)"><i class="bi bi-grid"></i></div>
                    <h5 class="fw-semibold">Catálogo</h5>
                    <p class="text-muted small">Consulta todos los productos registrados en el sistema.</p>
                    <a class="btn btn-primary" asp-page="/Productos/Index">Ver Productos</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="product-card text-center p-4">
                    <div class="mb-3" style="font-size:2.5rem;color:var(--success)"><i class="bi bi-plus-circle"></i></div>
                    <h5 class="fw-semibold">Agregar</h5>
                    <p class="text-muted small">Registra un nuevo producto en el catálogo.</p>
                    <a class="btn btn-success" asp-page="/Productos/Agregar">Nuevo Producto</a>
                </div>
            </div>
        </div>
    </div>
</div>
