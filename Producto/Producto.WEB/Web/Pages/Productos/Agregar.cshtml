@page
@model Web.Pages.Productos.AgregarModel
@{
    ViewData["Title"] = "Agregar Producto";
}

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-plus-circle me-2"></i>Agregar Producto</h1>
        <p>Complete los datos para registrar un nuevo producto.</p>
    </div>
</div>

<div class="section-body">
    <div class="container">

        <div class="mb-3">
            <a class="btn btn-outline-secondary btn-sm" asp-page="./Index">
                <i class="bi bi-arrow-left me-1"></i>Volver al listado
            </a>
        </div>

        <div class="form-card">
            <h4 class="fw-semibold mb-4"><i class="bi bi-box text-primary me-2"></i>Datos del Producto</h4>

            <form method="post">

                <div class="mb-3">
                    <label class="form-label" for="categorias">Categoría</label>
                    <select class="form-select" id="categorias" onchange="fetchSubCategorias()">
                        <option value="">Seleccione una categoría</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="subcategorias">SubCategoría</label>
                    <select asp-for="producto.IdSubCategoria" class="form-select"
                            asp-items="Model.subCategorias" id="subcategorias">
                        <option value="">Seleccione una subcategoría</option>
                    </select>
                    <span class="text-danger" asp-validation-for="producto.IdSubCategoria"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="producto.Nombre"></label>
                    <input class="form-control" asp-for="producto.Nombre" placeholder="Ej. Laptop HP Pavilion" />
                    <span class="text-danger" asp-validation-for="producto.Nombre"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="producto.Descripcion"></label>
                    <textarea class="form-control" asp-for="producto.Descripcion" rows="3"
                              placeholder="Descripción detallada del producto..."></textarea>
                    <span class="text-danger" asp-validation-for="producto.Descripcion"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="producto.Precio"></label>
                        <div class="input-group">
                            <span class="input-group-text">₡</span>
                            <input class="form-control" asp-for="producto.Precio" placeholder="0.00" />
                        </div>
                        <span class="text-danger" asp-validation-for="producto.Precio"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="producto.Stock"></label>
                        <input class="form-control" asp-for="producto.Stock" placeholder="0" />
                        <span class="text-danger" asp-validation-for="producto.Stock"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label" asp-for="producto.CodigoBarras"></label>
                    <input class="form-control" asp-for="producto.CodigoBarras" placeholder="Ej. 12345678" />
                    <span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
                </div>

                <div class="text-danger mb-3" asp-validation-summary="All"></div>

                <div class="d-flex gap-2">
                    <input type="submit" value="Guardar Producto" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" asp-page="./Index">Cancelar</a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        (async function () {
            try {
                const res = await fetch('?handler=ObtenerCategorias');
                if (!res.ok) return;
                const cats = await res.json();
                const sel = document.getElementById('categorias');
                cats.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.id;
                    opt.text = c.nombre;
                    sel.appendChild(opt);
                });
            } catch (e) {
                console.error('Error cargando categorías:', e);
            }
        })();

        async function fetchSubCategorias() {
            const catId = document.getElementById('categorias').value;
            const subSel = document.getElementById('subcategorias');
            subSel.innerHTML = '<option value="">Seleccione una subcategoría</option>';
            if (!catId) return;
            try {
                const res = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${catId}`);
                if (!res.ok) throw new Error('Error al obtener subcategorías');
                const subs = await res.json();
                subs.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.text = s.nombre;
                    subSel.appendChild(opt);
                });
            } catch (e) {
                console.error('Error cargando subcategorías:', e);
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
