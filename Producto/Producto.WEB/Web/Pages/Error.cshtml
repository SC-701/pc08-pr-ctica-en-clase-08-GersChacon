@page
@model Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="section-body">
    <div class="container text-center">
        <div style="font-size:4rem;color:var(--danger)"><i class="bi bi-exclamation-triangle"></i></div>
        <h2 class="mt-3">Ocurrió un error</h2>
        <p class="text-muted">Lo sentimos, algo salió mal.</p>
        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
        <a class="btn btn-primary mt-2" href="/">Volver al inicio</a>
    </div>
</div>
